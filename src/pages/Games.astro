---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import CallToAction from '../components/CallToAction.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// Filter for Game Dev projects and sort Newest First
const projects = (await getCollection('work'))
    .filter((project) => 
        project.data.tags.includes('Game Development') || 
        project.data.tags.includes('Programming')
    )
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
    title="Gavin Piliczky | Game Development"
    description="Explore game design, blueprints, and technical programming projects by Gavin Piliczky."
>
    <div class="stack gap-20">
        <main class="wrapper stack gap-8">
            <Hero
                title="Game Development"
                tagline="Technical prototypes, game jam entries, and interactive systems built in Unreal Engine Blueprints and GameMaker Language (GML)."
                align="start"
            />
            
            <Grid variant="offset">
                {
                    projects.map((project) => (
                        <li>
                            <PortfolioPreview project={project} />
                        </li>
                    ))
                }
            </Grid>

            {/* UPDATED CTA: Flows into Technical/VFX work */}
            <aside class="technical-cta">
                <div class="cta-text">
                    <p>Interested in the intersection of film and real-time tech?</p>
                    <small>Explore cinematics, camera tracking, and VFX compositing.</small>
                </div>
                <CallToAction href="/Tech/">
                    Technical Art & VFX
                    <Icon icon="terminal-window" size="1.2em" />
                </CallToAction>
            </aside>
        </main>
        <ContactCTA />
    </div>
</BaseLayout>

<style>
    .technical-cta {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        border-top: 1px solid var(--gray-800);
        padding-top: 5rem;
        margin-top: 2rem;
        text-align: center;
    }

    .cta-text p {
        font-size: var(--text-lg);
        max-width: 25ch;
        color: var(--gray-200);
        margin-bottom: 0.5rem;
    }

    .cta-text small {
        display: block;
        font-size: var(--text-md);
        color: var(--gray-400);
    }

    @media (min-width: 50em) {
        .technical-cta {
            flex-direction: row;
            justify-content: space-between;
            text-align: left;
        }

        .cta-text p {
            max-width: 40ch;
            font-size: var(--text-xl);
        }
    }
</style>