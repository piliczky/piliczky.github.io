---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import CallToAction from '../components/CallToAction.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const projectOrder = [
    '2D Weapon Concepts',
    'Pixel Art & Sprite Animation',
    'Character Art',
];

const projects = (await getCollection('work'))
    .filter((project) =>
        project.data.tags.includes('2D')
    )
    .sort(
        (a, b) =>
            projectOrder.indexOf(a.data.title) -
            projectOrder.indexOf(b.data.title)
    );
---

<BaseLayout
    title="Gavin Piliczky | 2D Art"
    description="Explore 2D artwork, illustrations, concept art, UI, and digital design projects by Gavin Piliczky."
>
    <div class="stack gap-20">
        <main class="wrapper stack gap-8">
            <Hero
                title="2D Art"
                tagline="Illustrations, digital artwork, UI design, concept art, and graphic design created for games and personal projects."
                align="start"
            />

            <Grid variant="offset">
                {
                    projects.map((project) => (
                        <li>
                            <PortfolioPreview project={project} />
                        </li>
                    ))
                }
            </Grid>

            <aside class="technical-cta">
                <div class="cta-text">
                    <p>Interested in my 3D work?</p>
                    <small>Explore game-ready assets, environments, and real-time art created in Blender, Maya, and Unreal Engine.</small>
                </div>
                <CallToAction href="/3D/">
                    View 3D Portfolio
                    <Icon icon="cube" size="1.2em" />
                </CallToAction>
            </aside>
        </main>

        <ContactCTA />
    </div>
</BaseLayout>

<style>
    .technical-cta {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        border-top: 1px solid var(--gray-800);
        padding-top: 5rem;
        margin-top: 2rem;
        text-align: center;
    }

    .cta-text p {
        font-size: var(--text-lg);
        max-width: 25ch;
        color: var(--gray-200);
        margin-bottom: 0.5rem;
    }

    .cta-text small {
        display: block;
        font-size: var(--text-md);
        color: var(--gray-400);
    }

    @media (min-width: 50em) {
        .technical-cta {
            flex-direction: row;
            justify-content: space-between;
            text-align: left;
        }

        .cta-text p {
            max-width: 40ch;
            font-size: var(--text-xl);
        }
    }
</style>
