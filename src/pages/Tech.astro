---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import CallToAction from '../components/CallToAction.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// Filter for Technical, Rigging, and Film projects
const projects = (await getCollection('work'))
    .filter((project) => 
        project.data.tags.includes('Technical') || 
        project.data.tags.includes('Rigging') ||
        project.data.tags.includes('VFX')
    )
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
    title="Technical Portfolio | Gavin Piliczky"
    description="Technical art, rigging, and Unreal Engine cinematic projects by Gavin Piliczky."
>
    <div class="stack gap-20">
        <main class="wrapper stack gap-8">
            <Hero
                title="Technical & Cinematics"
                tagline="A showcase of technical art, rigging systems, and cinematic storytelling in Unreal Engine."
                align="start"
            />
            
            <Grid variant="offset">
                {
                    projects.map((project) => (
                        <li>
                            <PortfolioPreview project={project} />
                        </li>
                    ))
                }
            </Grid>

            {/* ENHANCED CTA: Narrative focus on IT background & workflow */}
            <aside class="about-cta">
                <div class="cta-text">
                    <p>Building high-end visuals requires more than just an artistic eye. It requires a structured technical foundation.</p>
                    <small>Learn how my 15-year career in IT infrastructure and client support allows me to approach complex 3D pipelines and technical troubleshooting with a unique, professional perspective.</small>
                </div>
                <CallToAction href="/about/">
                    My Story & Process
                    <Icon icon="arrow-right" size="1.2em" />
                </CallToAction>
            </aside>
        </main>
        <ContactCTA />
    </div>
</BaseLayout>

<style>
    .about-cta {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        border-top: 1px solid var(--gray-800);
        padding-top: 5rem;
        margin-top: 2rem;
        text-align: center;
    }

    .cta-text p {
        font-size: var(--text-lg);
        max-width: 30ch;
        color: var(--gray-100);
        margin-bottom: 0.75rem;
        line-height: 1.2;
    }

    .cta-text small {
        display: block;
        font-size: var(--text-md);
        color: var(--gray-400);
        max-width: 45ch;
        line-height: 1.5;
    }

    @media (min-width: 50em) {
        .about-cta {
            flex-direction: row;
            justify-content: space-between;
            text-align: left;
            align-items: flex-start;
        }

        .cta-text p {
            max-width: 40ch;
            font-size: var(--text-xl);
        }

        .cta-text small {
            max-width: 50ch;
        }
    }
</style>