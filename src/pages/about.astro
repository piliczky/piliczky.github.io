---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Grid from '../components/Grid.astro';
import Skills from '../components/Skills.astro';

const technologies = [
    { name: 'Unreal Engine', slug: 'unrealengine' },
    { name: 'Maya', slug: 'autodeskmaya' },
    { name: 'ZBrush', icon: 'zbrush' }, 
    { name: 'Blender', slug: 'blender' },
    { name: 'Substance Painter', icon: 'adobe' },
    { name: 'Substance Designer', icon: 'adobe' },
    { name: 'GameMaker', slug: 'gamemaker' },
    { name: 'Photoshop', icon: 'photoshop' },
    { name: 'Premiere', icon: 'premiere' },
    { name: 'After Effects', icon: 'after-effects' },
    { name: 'Illustrator', icon: 'illustrator' },
    { name: 'Python', slug: 'python' },
];
---

<BaseLayout title="About | Gavin Piliczky" description="Learn more about Gavin Piliczky, a Game Developer and 3D Generalist based in Adelaide.">
    <div class="stack gap-20">
        <main class="wrapper about">
            <Hero
                title="About"
                tagline="Thanks for stopping by. Read below to learn more about my journey into game development."
            >
                <div class="hero-actions">
                    <a href="/assets/Resume/Piliczky_Gavin_Resume.pdf" class="resume-link" download>
                        Download Resume (PDF)
                    </a>
                </div>
                <img
                    src="/assets/at-work.jpg"
                    alt="Gavin Piliczky working on 3D assets"
                    class="about-portrait"
                />
            </Hero>

            <section>
                <h2 class="section-title">Background</h2>
                <div class="content">
                    <p>I am a Game Developer and 3D Artist based in Adelaide, Australia. My journey into game development began with a childhood passion for creating digital worlds. This goal eventually led me to the IT sector to build a deep technical foundation. Today, I combine that lifelong creative drive with a decade and a half of technical expertise to build immersive, optimized game experiences.</p>
                    <p>My work focuses on the intersection of art and code. I specialize in building game-ready assets and systems that balance high-fidelity visuals with the technical rigor required for modern pipelines. Whether I am modeling in Blender and Maya, texturing in Substance Painter, or scripting in Unreal Engine, my goal is always to ensure a seamless integration between the asset and the environment.</p>
                    <p>Having spent 15 years in IT support and infrastructure, I bring a unique perspective to development. I approach every project with a high-level focus on pipeline efficiency, documentation, and structured problem-solving. I am currently completing my Bachelor of Creative Arts at Flinders University and CDW Studios, where I continue to refine my skills in visual effects and entertainment design.</p>
                </div>
            </section>

            <section>
                <h2 class="section-title">Expertise</h2>
                <div class="content">
                    <Skills />
                </div>
            </section>
            
            <section>
                <h2 class="section-title">Education</h2>
                <div class="content">
                    <ul class="about-list">
                        <li>
                            <strong>Bachelor of Creative Arts (Visual Effects and Entertainment Design)</strong>
                            <p>Flinders University in conjunction with CDW Studios (Completing 2026)</p>
                        </li>
                        <li>
                            <strong>Advanced Diploma of Screen and Media (Content Creation and Design)</strong>
                            <p><a href="/assets/Resume/Piliczky_Gavin_Advanced_Diploma.png" target="_blank">Verify Certificate</a></p>
                        </li>
                        <li>
                            <strong>Diploma of Screen and Media (Animation, Gaming, and VFX)</strong>
                            <p><a href="/assets/Resume/Piliczky_Gavin_Diploma.png" target="_blank">Verify Certificate</a></p>
                        </li>
                        <li>
                            <strong>Certificate IV in Information Technology (Client Support)</strong>
                            <p><a href="/assets/Resume/Piliczky_Gavin_Cert_IV_IT.png" target="_blank">Verify Certificate</a></p>
                        </li>
                        <li>
                            <strong>Golden Key International Honour Society Member</strong>
                            <p>Recognized in the top 15% of students academically at Flinders University. <a href="https://golden-key-international-honou.verified.cv/en/verify/91529646150136" target="_blank">Verify Certificate</a></p>
                        </li>
                    </ul>
                </div>
            </section>

            <section class="tools-section">
                <h2 class="section-title">Tools & Tech</h2>
                <div class="content full-width">
                    <Grid variant="small">
                        {technologies.map((tech) => (
                            <li class="mention-card">
                                <div class="icon-container">
                                    {tech.icon ? (
                                        <Icon icon={tech.icon} size="2.5rem" />
                                    ) : (
                                        <img
                                            src={`https://cdn.simpleicons.org/${tech.slug}/ffffff`}
                                            alt={`${tech.name} logo`}
                                            loading="lazy"
                                        />
                                    )}
                                </div>
                                <p>{tech.name}</p>
                            </li>
                        ))}
                    </Grid>
                </div>
            </section>
        </main>

        <ContactCTA />
    </div>
</BaseLayout>

<style>
    .about {
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }

    .hero-actions {
        margin-top: 1.5rem;
        display: flex;
        justify-content: center;
    }

    .resume-link {
        display: inline-block;
        padding: 0.5rem 1.5rem;
        color: var(--accent-dark);
        border: 1px solid var(--accent-dark);
        border-radius: 999rem;
        text-decoration: none;
        font-size: var(--text-md);
        font-weight: 600;
        transition: background-color var(--theme-transition), color var(--theme-transition);
    }

    .resume-link:hover {
        background-color: var(--accent-dark);
        color: var(--gray-999);
    }

    .about-portrait {
        display: block;
        width: 100%;
        max-width: 300px;
        margin: 2rem auto 0;
        border-radius: 1.5rem;
        box-shadow: var(--shadow-md);
        object-fit: cover;
    }

    section {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        color: var(--gray-200);
    }

    .section-title {
        font-size: var(--text-xl);
        color: var(--gray-0);
    }

    .about-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .about-list li strong {
        color: var(--gray-0);
        display: block;
    }

    .about-list li a {
        color: var(--accent-regular);
        text-decoration: underline;
        text-underline-offset: 0.25rem;
    }

    .about-list li a:hover {
        color: var(--accent-light);
    }

    .mention-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        padding: 1.5rem;
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        text-align: center;
        min-height: 120px;
    }

    .icon-container {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
    }

    .icon-container img, 
    .icon-container :global(svg) {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .mention-card p {
        margin: 0;
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--gray-0);
        white-space: nowrap;
    }

    /* Grid Overrides for Tools */
    .full-width :global(.grid.small) {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        list-style: none;
        padding: 0;
    }

    @media (min-width: 50em) {
        .about {
            display: grid;
            grid-template-columns: 1fr 70% 1fr;
        }

        .about > :global(:first-child) {
            grid-column-start: 2;
        }

        section {
            display: contents;
        }

        .tools-section {
            display: block !important;
            grid-column: 2;
            margin-top: 2rem;
        }

        .tools-section .section-title {
            margin-bottom: 2rem;
        }

        .section-title {
            grid-column-start: 1;
        }

        .content {
            grid-column: 2 / 3;
        }

        .full-width :global(.grid.small) {
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }

        .about-portrait {
            max-width: 400px;
        }
    }

    :global(.skills) {
        border: none !important;
        padding: 0 !important;
        background: none !important;
    }
</style>