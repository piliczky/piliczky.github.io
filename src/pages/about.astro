---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Grid from '../components/Grid.astro';

const technologies = [
    { name: 'Unreal Engine', slug: 'unrealengine' },
    { name: 'Maya', slug: 'autodeskmaya' },
    { name: 'Blender', slug: 'blender' },
    { name: 'GameMaker', slug: 'gamemaker' },
    { name: 'Substance Painter', icon: 'adobe' },
    { name: 'Substance Designer', icon: 'adobe' },
    { name: 'Photoshop', icon: 'photoshop' },
    { name: 'Premiere', icon: 'premiere' },
    { name: 'Python', slug: 'python' },
];
---

<BaseLayout title="About | Gavin Piliczky" description="Learn more about Gavin Piliczky, a Game Developer and 3D Generalist based in Adelaide.">
    <div class="stack gap-20">
        <main class="wrapper about">
            <Hero
                title="About"
                tagline="Thanks for stopping by. Read below to learn more about my journey into game development."
            >
                <div class="hero-actions">
                    <a href="/assets/Resume/Piliczky_Gavin_Resume.pdf" class="resume-link" download>
                        Download Resume (PDF)
                    </a>
                </div>
                <img
                    src="/assets/at-work.jpg"
                    alt="Gavin Piliczky working on 3D assets"
                    class="about-portrait"
                />
            </Hero>

            <section>
                <h2 class="section-title">Background</h2>
                <div class="content">
                    <p>
                        I am a Game Developer and 3D Artist based in Adelaide, Australia. My journey into game development began with a childhood passion for creating digital worlds. This goal eventually led me to the IT sector to build a deep technical foundation. Today, I combine that lifelong creative drive with a decade and a half of technical expertise to build immersive, optimized game experiences.
                    </p>
                    <p>
                        My work focuses on the intersection of art and code. I specialize in building game-ready assets and systems that balance high-fidelity visuals with the technical rigor required for modern pipelines. Whether I am modeling in Blender and Maya, texturing in Substance Painter, or scripting in Unreal Engine, my goal is always to ensure a seamless integration between the asset and the environment.
                    </p>
                    <p>
                        Having spent 15 years in IT support and infrastructure, I bring a unique perspective to development. I approach every project with a high-level focus on pipeline efficiency, documentation, and structured problem-solving. I am currently completing my Bachelor of Creative Arts at Flinders University and CDW Studios, where I continue to refine my skills in visual effects and entertainment design.
                    </p>
                </div>
            </section>
            
            <section>
                <h2 class="section-title">Education</h2>
                <div class="content">
                    <ul class="about-list">
                        <li>
                            <strong>Bachelor of Creative Arts (Visual Effects and Entertainment Design)</strong>
                            <p>Flinders University in conjunction with CDW Studios (Completing 2026)</p>
                        </li>
                        <li>
                            <strong>Advanced Diploma of Screen and Media (Content Creation and Design)</strong>
                        </li>
                        <li>
                            <strong>Diploma of Screen and Media (Animation, Gaming, and VFX)</strong>
                        </li>
                        <li>
                            <strong>Certificate IV in Information Technology (Client Support)</strong>
                        </li>
                        <li>
                            <strong>Golden Key International Honour Society Member</strong>
                            <p>Recognized in the top 15% of students academically at Flinders University. <a href="https://golden-key-international-honou.verified.cv/en/verify/91529646150136">Verify Certificate</a></p>
                        </li>
                    </ul>
                </div>
            </section>

            <section>
                <h2 class="section-title">Tools & Tech</h2>
                <div class="content">
                    <div class="gallery">
                        <Grid variant="small">
                            {technologies.map((tech) => (
                                <li class="mention-card">
                                    {tech.icon ? (
                                        <Icon icon={tech.icon} size="2.5rem" />
                                    ) : (
                                        <img
                                            src={`https://cdn.simpleicons.org/${tech.slug}/ffffff`}
                                            alt={`${tech.name} logo`}
                                            loading="lazy"
                                            class="mention-icon"
                                        />
                                    )}
                                    <p>{tech.name}</p>
                                </li>
                            ))}
                        </Grid>
                    </div>
                </div>
            </section>
        </main>

        <ContactCTA />
    </div>
</BaseLayout>

<style>
    .about {
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }

    .hero-actions {
        margin-top: 1.5rem;
        display: flex;
        justify-content: center;
    }

    .resume-link {
        display: inline-block;
        padding: 0.5rem 1.5rem;
        color: var(--accent-dark);
        border: 1px solid var(--accent-dark);
        border-radius: 999rem;
        text-decoration: none;
        font-size: var(--text-md);
        font-weight: 600;
        transition: background-color var(--theme-transition), color var(--theme-transition), border-color var(--theme-transition);
    }

    .resume-link:hover {
        background-color: var(--accent-dark);
        color: var(--gray-999);
    }

    .about-portrait {
        display: block;
        width: 40%;
        margin: 1.5rem auto 0;
        border-radius: 1.5rem;
        box-shadow: var(--shadow-md);
    }

    section {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        color: var(--gray-200);
    }

    .section-title {
        grid-column-start: 1;
        font-size: var(--text-xl);
        color: var(--gray-0);
    }

    .content {
        grid-column: 2 / 4;
    }

    .about-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .about-list li strong {
        color: var(--gray-0);
        display: block;
        margin-bottom: 0.25rem;
    }

    .about-list li p {
        margin: 0;
        font-size: var(--text-md);
    }

    .mention-card {
        display: grid;
        place-items: center;
        gap: 0.8rem;
        min-height: 9rem;
        padding: 1.2rem;
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .mention-icon, :global(.mention-card svg) {
        width: 2.5rem;
        height: 2.5rem;
    }

    .mention-card p {
        margin: 0;
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--gray-0);
    }

    @media (min-width: 50em) {
        .about {
            display: grid;
            grid-template-columns: 1fr 60% 1fr;
        }

        .about > :global(:first-child) {
            grid-column-start: 2;
        }

        section {
            display: contents;
            font-size: var(--text-lg);
        }

        .about-portrait {
            width: 33%;
        }
    }
</style>