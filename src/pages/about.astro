---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Gavin Piliczky" description="Learn more about Gavin Piliczky, a Game Developer and 3D Generalist based in Adelaide.">
    <div class="stack gap-20">
        <main class="wrapper about">
            <Hero
                title="About"
                tagline="Thanks for stopping by. Read below to learn more about my journey from IT to Game Development."
            >
                <img
                    width="35%"
                    height="35%"
                    src="/assets/at-work.jpg"
                    alt="Gavin Piliczky working on 3D assets"
                />
            </Hero>

            <section>
                <h2 class="section-title">Background</h2>
                <div class="content">
                    <p>
                        I’m a Game Developer and 3D Generalist based in Adelaide, Australia. My approach to game art is driven by a unique blend of technical precision and creative exploration. I specialize in building game-ready assets and systems that are not only visually compelling but also technically optimized for modern development pipelines.
                    </p>
                    <p>
                        Prior to shifting my focus toward the creative arts, I spent over 15 years working in the IT sector. This extensive background in technical support and infrastructure provided me with a high-level perspective on problem-solving, documentation, and pipeline efficiency—skills that I now apply directly to game development and technical art.
                    </p>
                    <p>
                        I am passionate about the intersection of art and code, frequently bridging the gap between the two using Unreal Engine, Substance Painter, and various scripting languages to ensure a seamless integration of assets into real-time environments.
                    </p>
                </div>
            </section>
            
            <section>
                <h2 class="section-title">Education</h2>
                <div class="content">
                    <p>
                        <strong>Bachelor of Creative Arts (Visual Effects and Entertainment Design)</strong><br />
                        Flinders University in conjunction with CDW Studios (6 weeks remaining)
                    </p>
                    <p>
                        <strong>Advanced Diploma of Screen and Media (Content Creation and Design)</strong>
                    </p>
                    <p>
                        <strong>Diploma of Screen and Media (Animation, Gaming, and VFX)</strong>
                    </p>
                    <p>
                        <strong>Certificate IV in Information Technology (Client Support)</strong>
                    </p>
                    <p>
                        <strong>Golden Key International Honour Society</strong><br />
                        Member - Top 15% of students academically at Flinders University<br />
                        <a href="https://golden-key-international-honou.verified.cv/en/verify/91529646150136">Verify Certificate</a>
                    </p>
                </div>
            </section>

            <section>
                <h2 class="section-title">Skills</h2>
                <div class="content">
                    <p>
                        <strong>Creative:</strong> 3D Modeling, Texturing, Material Creation, Asset Development, Environment Design.
                    </p>
                    <p>
                        <strong>Technical:</strong> Unreal Engine Blueprints, C#, Python, GML, Pipeline Optimization, IT Systems Support.
                    </p>
                    <p>
                        <strong>Software:</strong> Unreal Engine, Substance Painter, Blender, Photoshop, Maya.
                    </p>
                </div>
            </section>
        </main>

        <ContactCTA />
    </div>
</BaseLayout>

<style>
    .about {
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }

    img {
        display: block;
        margin: 1.5rem auto 0;
        border-radius: 1.5rem;
        box-shadow: var(--shadow-md);
    }

    section {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        color: var(--gray-200);
    }

    .section-title {
        grid-column-start: 1;
        font-size: var(--text-xl);
        color: var(--gray-0);
    }

    .content {
        grid-column: 2 / 4;
    }

    .content :global(a) {
        text-decoration: 1px solid underline transparent;
        text-underline-offset: 0.25em;
        transition: text-decoration-color var(--theme-transition);
    }

    .content :global(a:hover),
    .content :global(a:focus) {
        text-decoration-color: currentColor;
    }

    @media (min-width: 50em) {
        .about {
            display: grid;
            grid-template-columns: 1fr 60% 1fr;
        }

        .about > :global(:first-child) {
            grid-column-start: 2;
        }

        section {
            display: contents;
            font-size: var(--text-lg);
        }
    }
</style>