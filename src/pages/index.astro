---
import { getCollection } from 'astro:content';
import CallToAction from '../components/CallToAction.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// Filter for 3D work and sort by date (Newest First)
const projects = (await getCollection('work'))
    .filter((project) => 
        project.data.tags.includes('3D Modeling')
    )
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
    title=" Gavin Piliczky | 3D Art"
    description="The professional portfolio of Gavin Piliczky, 3D Generalist and Game Developer."
>
    <div class="stack gap-20">
        <main class="wrapper stack gap-8">
            {/* SECTION 1: HERO HEADER */}
            <Hero
                title="3D Art & Assets"
                tagline="High-fidelity models, environment art, and textured props designed for games and real-time engines."
                align="start"
            />

            <div class="gallery">
                <Grid variant="offset">
                    {projects.map((project) => (
                        <li>
                            <PortfolioPreview project={project} />
                        </li>
                    ))}
                </Grid>
            </div>

            {/* SECTION 1.5: GAMES CTA */}
            <aside class="games-cta">
                <p>Looking for interactive projects and gameplay prototypes?</p>
                <CallToAction href="/Games/">
                    View My Games
                    <Icon icon="game-controller" size="1.2em" />
                </CallToAction>
            </aside>
        </main>

        {/* SECTION 2: ABOUT / BIO */}
        <div class="wrapper">
            <header class="home-hero-grid">
                <div class="hero-text-section">
                    <Hero
                        title="Bridging 3D art and code"
                        tagline="Game prototypes, technical art tools, and 3D models built to feel ready for play."
                        align="start"
                    >
                        <div class="roles">
                            <Pill><Icon icon="castle" size="1.33em" /> Game Developer</Pill>
                            <Pill><Icon icon="perspective" size="1.33em" /> 3D Generalist</Pill>
                            <Pill><Icon icon="terminal-window" size="1.33em" /> Technical Artist</Pill>
                        </div>
                    </Hero>
                </div>

                <div class="hero-image-section">
                    <img
                        alt="Gavin Piliczky"
                        src="/assets/at-work.jpg"
                        class="portrait-img"
                    />
                </div>
            </header>
        </div>

        <ContactCTA />
    </div>

    <style>
        /* Games CTA Section */
        .games-cta {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2rem;
            border-top: 1px solid var(--gray-800);
            border-bottom: 1px solid var(--gray-800);
            padding: 5rem 1.5rem;
            background-color: var(--gray-999_40);
            box-shadow: var(--shadow-sm);
        }

        .games-cta p {
            font-size: var(--text-lg);
            max-width: 25ch;
            text-align: center;
        }

        /* About / Bio Grid */
        .home-hero-grid {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2rem;
            margin-bottom: 1rem;
            border-top: 1px solid var(--gray-800);
            padding-top: 5rem;
        }

        .portrait-img {
            width: 100%;
            max-width: 280px;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border-radius: 2rem;
            box-shadow: var(--shadow-md);
        }

        .roles {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        @media (min-width: 50em) {
            .games-cta {
                flex-direction: row;
                justify-content: space-between;
                text-align: left;
            }

            .games-cta p {
                text-align: left;
                max-width: none;
                font-size: var(--text-xl);
            }

            .home-hero-grid {
                flex-direction: row;
                justify-content: space-between;
                align-items: flex-start;
                gap: 4rem;
            }

            .hero-text-section {
                flex: 2;
                text-align: left;
            }

            .hero-image-section {
                flex: 1;
                display: flex;
                justify-content: flex-end;
            }

            .portrait-img {
                width: 100%;
                max-width: 320px;
                aspect-ratio: 3 / 4;
                border-radius: 3rem;
            }
        }
    </style>
</BaseLayout>