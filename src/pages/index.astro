---
import { getCollection } from 'astro:content';
import CallToAction from '../components/CallToAction.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Skills from '../components/Skills.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('work'))
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
    .slice(0, 4);
---

<BaseLayout>
    <div class="stack gap-10 lg:gap-16">
        <div class="wrapper">
            <header class="home-hero-grid">
                <div class="hero-text-section">
                    <Hero
                        title="Bridging 3D art and code"
                        tagline="Game prototypes, technical art tools, and 3D models built to feel ready for play."
                        align="start"
                    >
                        <div class="roles">
                            <Pill><Icon icon="castle" size="1.33em" /> Game Developer</Pill>
                            <Pill><Icon icon="perspective" size="1.33em" /> 3D Generalist</Pill>
                            <Pill><Icon icon="terminal-window" size="1.33em" /> Technical Artist</Pill>
                        </div>
                    </Hero>
                </div>

                <div class="hero-image-section">
                    <img
                        alt="Gavin Piliczky"
                        src="/assets/at-work.jpg"
                        class="portrait-img"
                    />
                </div>
            </header>
        </div>

        <main class="wrapper stack gap-20 lg:gap-32">
            <section class="section with-background with-cta">
                <header class="section-header stack gap-2 lg:gap-4">
                    <h3>Selected Work</h3>
                    <p>Explore my featured game development projects, 3D assets, and technical prototypes.</p>
                </header>

                <div class="gallery">
                    <Grid variant="offset">
                        {projects.map((project) => (
                            <li>
                                <PortfolioPreview project={project} />
                            </li>
                        ))}
                    </Grid>
                </div>
                <div class="cta">
                    <CallToAction href="/work/">
                        View All
                        <Icon icon="arrow-right" size="1.2em" />
                    </CallToAction>
                </div>
            </section>

            {/* This now acts as the final summary of your expertise on the home page */}
            <Skills />
        </main>

        <ContactCTA />
    </div>

    <style>
        .home-hero-grid {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2rem;
            margin-bottom: 1rem;
        }

        .portrait-img {
            width: 100%;
            max-width: 280px;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border-radius: 2rem;
            box-shadow: var(--shadow-md);
        }

        .roles {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        @media (min-width: 50em) {
            .home-hero-grid {
                flex-direction: row;
                justify-content: space-between;
                align-items: flex-start;
                gap: 4rem;
                padding-top: 2rem;
            }

            .hero-text-section {
                flex: 2;
                text-align: left;
            }

            .hero-image-section {
                flex: 1;
                display: flex;
                justify-content: flex-end;
            }

            .portrait-img {
                width: 100%;
                max-width: 320px;
                aspect-ratio: 3 / 4;
                border-radius: 3rem;
            }
        }
    </style>
</BaseLayout>