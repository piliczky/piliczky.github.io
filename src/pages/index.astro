---
import { getCollection } from 'astro:content';
import CallToAction from '../components/CallToAction.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Skills from '../components/Skills.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('work'))
    .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
    .slice(0, 4);

const technologies = [
    { name: 'Unreal Engine', slug: 'unrealengine' },
    { name: 'Maya', slug: 'autodeskmaya' },
    { name: 'Blender', slug: 'blender' },
    { name: 'GameMaker', slug: 'gamemaker' },
    { name: 'Substance Painter', icon: 'adobe' },
    { name: 'Substance Designer', icon: 'adobe' },
    { name: 'Photoshop', icon: 'photoshop' },
    { name: 'Premiere', icon: 'premiere' },
    { name: 'Python', slug: 'python' },
];
---

<BaseLayout>
    <div class="stack gap-20 lg:gap-48">
        <div class="wrapper">
            <header class="home-hero-grid">
                <div class="hero-text-section">
                    <Hero
                        title="Bridging 3D art and code"
                        tagline="Game prototypes, technical art tools, and 3D models built to feel ready for play."
                        align="start"
                    >
                        <div class="roles">
                            <Pill><Icon icon="castle" size="1.33em" /> Game Developer</Pill>
                            <Pill><Icon icon="perspective" size="1.33em" /> 3D Generalist</Pill>
                            <Pill><Icon icon="terminal-window" size="1.33em" /> Technical Artist</Pill>
                        </div>
                    </Hero>
                </div>

                <div class="hero-image-section">
                    <img
                        alt="Gavin Piliczky"
                        src="/assets/at-work.jpg"
                        class="portrait-img"
                    />
                </div>
            </header>

            <Skills />
        </div>

        <main class="wrapper stack gap-20 lg:gap-48">
            <section class="section with-background with-cta">
                <header class="section-header stack gap-2 lg:gap-4">
                    <h3>Selected Work</h3>
                    <p>Explore my featured game development projects, 3D assets, and technical prototypes.</p>
                </header>

                <div class="gallery">
                    <Grid variant="offset">
                        {projects.map((project) => (
                            <li>
                                <PortfolioPreview project={project} />
                            </li>
                        ))}
                    </Grid>
                </div>
                <div class="cta">
                    <CallToAction href="/work/">
                        View All
                        <Icon icon="arrow-right" size="1.2em" />
                    </CallToAction>
                </div>
            </section>

            <section class="section with-background bg-variant">
                <header class="section-header stack gap-2 lg:gap-4">
                    <h3>Tools & Technologies</h3>
                    <p>I bridge the gap between art and code using industry-standard software and scripting languages.</p>
                </header>
                <br>
                <div class="gallery">
                    <Grid variant="small">
                        {technologies.map((tech) => (
                            <li class="mention-card">
                                {tech.icon ? (
                                    <Icon icon={tech.icon} size="2.5rem" />
                                ) : (
                                    <img
                                        src={`https://cdn.simpleicons.org/${tech.slug}/ffffff`}
                                        alt={`${tech.name} logo`}
                                        loading="lazy"
                                        class="mention-icon"
                                    />
                                )}
                                <p>{tech.name}</p>
                            </li>
                        ))}
                    </Grid>
                </div>
            </section>
        </main>

        <ContactCTA />
    </div>

    <style>
        .home-hero-grid {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2rem;
            margin-bottom: 3rem;
        }

        .portrait-img {
            width: 100%;
            max-width: 280px; /* Limits size on mobile */
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border-radius: 2rem;
            box-shadow: var(--shadow-md);
        }

        .roles {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        /* Desktop Layout Override */
        @media (min-width: 50em) {
            .home-hero-grid {
                flex-direction: row;
                justify-content: space-between;
                align-items: flex-start; /* Aligns text and image top */
                gap: 4rem;
                padding-top: 2rem;
            }

            .hero-text-section {
                flex: 2; /* 2/3rds of the space */
                text-align: left;
            }

            .hero-image-section {
                flex: 1; /* 1/3rd of the space */
                display: flex;
                justify-content: flex-end;
            }

            .portrait-img {
                width: 100%;
                max-width: 320px; /* Keep it tight and professional */
                aspect-ratio: 3 / 4;
                border-radius: 3rem;
            }
        }

        /* Skills/Mention Card Styles */
        .mention-card {
            display: grid;
            place-items: center;
            gap: 0.8rem;
            min-height: 9rem;
            padding: 1.2rem;
            border-radius: 1.5rem;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .mention-icon, :global(.mention-card svg) {
            width: 2.5rem;
            height: 2.5rem;
        }

        .mention-card p {
            margin: 0;
            font-size: var(--text-sm);
            font-weight: 600;
            color: var(--gray-0);
        }
    </style>
</BaseLayout>