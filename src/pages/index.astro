---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const work = await getCollection('work');

const threeDOrder = [
    'vintage-camera',
    'stylised_courtyard',
    'gibson-guitar',
    'offroad-vehicle',
    'spyro-dragon',
    'bathroom',
];

const threeDProjects = work
    .filter((project) => project.data.tags.includes('3D Modeling'))
    .sort((a, b) => {
        const aSlug = a.id.split('/').at(-1) ?? '';
        const bSlug = b.id.split('/').at(-1) ?? '';
        return threeDOrder.indexOf(aSlug) - threeDOrder.indexOf(bSlug);
    });

const unrealAndGameOrder = [
    'zombie-derby',
    'swarmex',
    'the-fortune-taker',
    'space-mission-to-mars',
];

const unrealAndGameProjects = work
    .filter((project) => {
        const slug = project.id.split('/').at(-1) ?? '';
        return unrealAndGameOrder.includes(slug);
    })
    .sort((a, b) => {
        const aSlug = a.id.split('/').at(-1) ?? '';
        const bSlug = b.id.split('/').at(-1) ?? '';
        return unrealAndGameOrder.indexOf(aSlug) - unrealAndGameOrder.indexOf(bSlug);
    });
---

<BaseLayout
    title="Gavin Piliczky | 3D Artist & Game Developer"
    description="3D art and game development portfolio by Gavin Piliczky, specialising in asset creation, Unreal Engine and Blueprint systems."
>
    <div class="stack gap-20">
        <main class="wrapper stack gap-12">
            <section class="intro">
                <h1>3D Artist & Game Developer</h1>
                <p>I create 3D assets and build gameplay systems in Unreal Engine and Blueprints, using Maya and Substance Painter for asset production.</p>
            </section>

            <section id="game-development" class="portfolio-section stack gap-6">
                <header class="section-heading">
                    <h2>Unreal Engine & Game Development</h2>
                </header>

                <ul class="game-grid">
                    {unrealAndGameProjects.map((project) => (
                        <li>
                            <PortfolioPreview project={project} />
                        </li>
                    ))}
                </ul>
            </section>

            <section id="3d-work" class="portfolio-section stack gap-6">
                <header class="section-heading">
                    <h2>3D Art & Assets</h2>
                </header>

                <Grid>
                    {threeDProjects.map((project) => (
                        <li>
                            <PortfolioPreview project={project} />
                        </li>
                    ))}
                </Grid>
            </section>

            <aside class="supporting-work">
                <p>Additional work</p>
                <a href="/Tech/">VFX & Cinematics</a>
                <a href="/2D/">2D Art</a>
            </aside>
        </main>

        <ContactCTA />
    </div>
</BaseLayout>

<style>
    .intro {
        padding: 1rem 0 2rem;
    }

    .intro h1 {
        max-width: none;
        color: var(--gray-0);
        font-size: var(--text-3xl);
    }

    .intro p {
        max-width: 72ch;
        margin-top: 1rem;
        color: var(--gray-300);
        font-size: var(--text-lg);
    }

    .game-grid {
        display: grid;
        gap: 1rem;
        padding: 0;
        list-style: none;
    }

    :global(.game-grid .card img) {
        object-fit: contain;
        object-position: center;
        background: var(--gray-999);
    }

    .supporting-work a {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        width: fit-content;
        color: var(--gray-200);
        font-family: var(--font-brand);
        font-size: var(--text-lg);
        font-weight: 500;
        text-decoration: none;
        text-underline-offset: 0.3em;
    }

    .supporting-work a:hover,
    .supporting-work a:focus {
        color: var(--gray-0);
        text-decoration: underline;
    }

    .section-heading {
        padding-top: 0.5rem;
    }

    #game-development .section-heading {
        margin-bottom: 0.5rem;
    }

    .section-heading h2,
    .supporting-work p {
        color: var(--gray-0);
        font-size: var(--text-2xl);
    }

    .supporting-work {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 1rem 2rem;
        padding-top: 2rem;
    }

    @media (min-width: 50em) {
        .intro {
            padding-top: 1.5rem;
        }

        .intro h1 {
            font-size: var(--text-5xl);
        }

        .section-heading h2,
        .supporting-work p {
            font-size: var(--text-3xl);
        }

        .game-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 2rem;
        }

        .game-grid > :last-child:nth-child(odd) {
            width: calc(50% - 1rem);
            grid-column: 1 / -1;
            justify-self: center;
        }
    }
</style>
